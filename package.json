{
  "name": "watchboard",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "copy-cesium": "node -e \"const{cpSync,existsSync}=require('fs');const s='node_modules/cesium/Build/Cesium/';['Workers','ThirdParty','Assets','Widgets'].forEach(d=>{if(!existsSync('public/cesium/'+d))cpSync(s+d,'public/cesium/'+d,{recursive:true})})\"",
    "dev": "npm run copy-cesium && astro dev",
    "check": "astro check",
    "generate-api": "tsx scripts/generate-api.ts",
    "build": "npm run generate-api && npm run copy-cesium && astro build",
    "postbuild": "npx pagefind --site dist --glob '**/*.html'",
    "preview": "astro preview",
    "update-data": "tsx scripts/update-data.ts",
    "backfill": "tsx scripts/backfill.ts",
    "backfill-gaps": "tsx scripts/backfill-gaps.ts",
    "backfill-osint": "tsx scripts/backfill-osint.ts",
    "backfill-media": "tsx scripts/backfill-media.ts",
    "backfill-wikimedia": "tsx scripts/backfill-wikimedia.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "generate-vapid-keys": "tsx scripts/generate-vapid-keys.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.18.0",
    "cesium": "^1.139.1",
    "globe.gl": "^2.45.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "resium": "^1.19.4",
    "satellite.js": "^6.0.2",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@atproto/api": "^0.15.27",
    "@aws-sdk/client-bedrock-runtime": "^3.1030.0",
    "@cloudflare/workers-types": "^4.20260410.1",
    "@playwright/test": "^1.58.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.3.3",
    "openai": "^6.25.0",
    "pagefind": "^1.4.0",
    "tsx": "^4.21.0",
    "twitter-api-v2": "^1.29.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^3.25.76"
  }
}
