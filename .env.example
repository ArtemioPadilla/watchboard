# PostHog Analytics (optional — omit to disable tracking in local dev)
# PUBLIC_POSTHOG_KEY=phc_your_project_key
# PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────────────────────────────
# Telegram (for `make video-repost-telegram` and `make video-redo-all`)
# Get a bot token from @BotFather on Telegram, then add the bot as
# admin to your channel. The CHANNEL_ID can be @yourchannel or a
# numeric chat id (negative for channels: -100xxxxxxxxxx).
# ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
