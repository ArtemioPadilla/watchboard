---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  trackerSlug?: string;
  githubRepo?: string;
}

const { title, description, trackerSlug, githubRepo } = Astro.props;
const siteUrl = import.meta.env.SITE || 'https://artemiopadilla.github.io';
const base = import.meta.env.BASE_URL || '/watchboard';
const basePath = base.endsWith('/') ? base : `${base}/`;
const pageUrl = trackerSlug ? `${siteUrl}${basePath}${trackerSlug}/` : `${siteUrl}${basePath}`;
const desc = description || 'Multi-topic intelligence dashboard with sourced data, interactive maps, and contested claims tracking.';
const githubUrl = githubRepo ? `https://github.com/${githubRepo}` : 'https://github.com/ArtemioPadilla/watchboard';
const ogImageUrl = trackerSlug
  ? `${siteUrl}${basePath}og/${trackerSlug}.png`
  : undefined;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={desc}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={desc}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={pageUrl}>
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
  {ogImageUrl && <meta property="og:image:width" content="1200" />}
  {ogImageUrl && <meta property="og:image:height" content="630" />}
  <meta name="twitter:card" content="summary_large_image">
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
  <meta name="theme-color" content="#0d1117">
  <meta http-equiv="X-Content-Type-Options" content="nosniff">
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <link rel="manifest" href={`${basePath}manifest.json`}>
  <link rel="canonical" href={pageUrl}>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔴</text></svg>">
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": title,
    "description": desc,
    "url": pageUrl,
  })} />
  <link rel="alternate" type="application/rss+xml" title={trackerSlug ? `${title} RSS` : 'Watchboard RSS'} href={trackerSlug ? `${basePath}${trackerSlug}/rss.xml` : `${basePath}rss.xml`} />
  <link rel="preload" as="font" type="font/woff2" crossorigin href="/watchboard/fonts/dm-sans-latin.woff2">
  <link rel="preload" as="font" type="font/woff2" crossorigin href="/watchboard/fonts/jetbrains-mono-latin.woff2">
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <div class="tooltip" id="tooltip"></div>
  <a
    class="feedback-fab"
    href={`${githubUrl}/issues/new/choose`}
    target="_blank"
    rel="noopener noreferrer"
    title="Report issue or suggest a feature"
    aria-label="Report issue or suggest a feature"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
  </a>
  <slot />

  <script>
    const observer = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    if ('serviceWorker' in navigator) {
      // Unregister any foreign service worker (e.g. from main site)
      // that may be caching /watchboard/ routes incorrectly
      navigator.serviceWorker.getRegistrations().then(regs => {
        for (const reg of regs) {
          if (reg.scope && !reg.scope.includes('/watchboard')) reg.unregister();
        }
      });
      // Register Watchboard service worker
      navigator.serviceWorker.register('/watchboard/sw.js');
    }
  </script>
</body>
</html>
