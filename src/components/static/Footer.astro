---
import type { Meta } from '../../lib/schemas';

interface Props {
  meta: Meta;
  trackerSlug?: string;
  githubRepo?: string;
}

const { meta, trackerSlug, githubRepo } = Astro.props;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const aboutHref = trackerSlug ? `${basePath}${trackerSlug}/about/` : `${basePath}about/`;
const rssHref = trackerSlug ? `${basePath}${trackerSlug}/rss.xml` : `${basePath}rss.xml`;
const githubUrl = githubRepo ? `https://github.com/${githubRepo}` : 'https://github.com/ArtemioPadilla/watchboard';
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-links">
      <a href={aboutHref}>About &amp; Credits</a>
      <span class="footer-sep">&middot;</span>
      <a href={rssHref} title="RSS Feed" class="footer-rss">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: -2px; margin-right: 3px;"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>RSS Feed
      </a>
      <span class="footer-sep">&middot;</span>
      <a href={`${basePath}metrics/`}>Status</a>
      <span class="footer-sep">&middot;</span>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-sep">&middot;</span>
      <a href="https://artemiop.com/">artemiop.com</a>
      <span class="footer-sep">&middot;</span>
      <span class="footer-updated">Last updated: {meta.lastUpdated}</span>
    </div>
    <div class="footer-note">{meta.footerNote} <span class="footer-sep">&middot;</span> Does not endorse any particular narrative.</div>
  </div>
</footer>
