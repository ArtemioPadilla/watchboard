---
import type { Meta } from '../../lib/schemas';

interface Props {
  meta: Meta;
  trackerSlug?: string;
  githubRepo?: string;
}

const { meta, trackerSlug, githubRepo } = Astro.props;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const aboutHref = trackerSlug ? `${basePath}${trackerSlug}/about/` : `${basePath}about/`;
const rssHref = trackerSlug ? `${basePath}${trackerSlug}/rss.xml` : `${basePath}rss.xml`;
const githubUrl = githubRepo ? `https://github.com/${githubRepo}` : 'https://github.com/ArtemioPadilla/watchboard';
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-links">
      <a href={aboutHref}><span data-i18n data-es="Acerca de y Créditos" data-fr="À propos et Crédits" data-pt="Sobre e Créditos">About &amp; Credits</span></a>
      <span class="footer-sep">&middot;</span>
      <a href={rssHref} title="RSS Feed" class="footer-rss">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: -2px; margin-right: 3px;"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg><span data-i18n data-es="Fuente RSS" data-fr="Flux RSS" data-pt="Feed RSS">RSS Feed</span>
      </a>
      <span class="footer-sep">&middot;</span>
      <a href={`${basePath}metrics/`}><span data-i18n data-es="Estado" data-fr="Statut" data-pt="Status">Status</span></a>
      <span class="footer-sep">&middot;</span>
      <a href={`${basePath}videos/`}><span data-i18n data-es="Videos" data-fr="Vidéos" data-pt="Vídeos">Videos</span></a>
      <span class="footer-sep">&middot;</span>
      <a href={`${basePath}vote/`}><span data-i18n data-es="Votar" data-fr="Voter" data-pt="Votar">Vote</span></a>
      <span class="footer-sep">&middot;</span>
      <a href={`${basePath}social/`}>Social</a>
      <span class="footer-sep">&middot;</span>
      <a href="https://t.me/watchboard_dev" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: -2px; margin-right: 2px;"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>Telegram
      </a>
      <span class="footer-sep">&middot;</span>
      <a href="https://bsky.app/profile/watchboard.bsky.social" target="_blank" rel="noopener noreferrer">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 568 501" fill="currentColor" style="vertical-align: -2px; margin-right: 2px;"><path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.21C491.866-1.611 568-28.906 568 57.947c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 323.8 536.444 388.56 473.333 453.32c-119.86 122.992-172.272-30.859-185.702-70.281-2.462-7.227-3.614-10.608-3.631-7.733-.017-2.875-1.169.506-3.631 7.733-13.43 39.422-65.842 193.273-185.702 70.281-63.111-64.76-33.89-129.52 80.986-149.071-65.72 11.185-139.6-7.295-159.875-79.748C10.945 203.659 1 75.291 1 57.946 1-28.906 77.135-1.611 123.121 33.664z"/></svg>Bluesky
      </a>
      <span class="footer-sep">&middot;</span>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-sep">&middot;</span>
      <a href="https://artemiop.com/">artemiop.com</a>
      <span class="footer-sep">&middot;</span>
      <span class="footer-updated"><span data-i18n data-es="Última actualización:" data-fr="Dernière mise à jour :" data-pt="Última atualização:">Last updated:</span> {meta.lastUpdated}</span>
    </div>
    <div class="footer-note">{meta.footerNote} <span class="footer-sep">&middot;</span> <span data-i18n data-es="No respalda ninguna narrativa en particular." data-fr="Ne soutient aucun récit en particulier." data-pt="Não endossa nenhuma narrativa em particular.">Does not endorse any particular narrative.</span></div>
  </div>
</footer>
