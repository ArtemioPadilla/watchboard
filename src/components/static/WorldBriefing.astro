---
/**
 * WorldBriefing.astro — static section showing latest digest entries from all active trackers.
 * Rendered at build time, zero client-side JavaScript.
 */

export interface BriefingItem {
  slug: string;
  name: string;
  emoji: string;
  date: string;
  title: string;
  summary: string;
  sectionsUpdated: string[];
  lastUpdated: string;
}

interface Props {
  items: BriefingItem[];
  basePath: string;
}

const { items, basePath } = Astro.props;

function relativeTime(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const hours = Math.floor(diff / 3600000);
  if (hours < 1) return 'just now';
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
}

function recencyClass(dateStr: string): string {
  const diff = Date.now() - new Date(dateStr).getTime();
  const hours = diff / 3600000;
  if (hours < 6) return 'wb-recency-green';
  if (hours < 24) return 'wb-recency-amber';
  return 'wb-recency-red';
}

/** Map section names to a CSS accent class for badge coloring. */
const SECTION_COLORS: Record<string, string> = {
  events: 'wb-badge-blue',
  timeline: 'wb-badge-blue',
  kpis: 'wb-badge-amber',
  map: 'wb-badge-green',
  'map-points': 'wb-badge-green',
  'map-lines': 'wb-badge-green',
  mapPoints: 'wb-badge-green',
  mapLines: 'wb-badge-green',
  casualties: 'wb-badge-red',
  political: 'wb-badge-purple',
  econ: 'wb-badge-amber',
  assets: 'wb-badge-blue',
  meta: 'wb-badge-dim',
  military: 'wb-badge-red',
  claims: 'wb-badge-purple',
};

function badgeClass(section: string): string {
  return SECTION_COLORS[section] ?? 'wb-badge-dim';
}

function formatSectionLabel(s: string): string {
  return s.replace(/([A-Z])/g, ' $1').replace(/-/g, ' ').trim().toUpperCase();
}
---

{items.length > 0 && (
  <section class="wb-section" aria-label="World Briefing">
    <div class="wb-container">
      <header class="wb-header">
        <h2 class="wb-title">WORLD BRIEFING</h2>
        <span class="wb-subtitle">{items.length} tracker{items.length !== 1 ? 's' : ''} updated in the last 7 days</span>
      </header>

      <div class="wb-grid">
        {items.map((item) => (
          <a href={`${basePath}${item.slug}/`} class="wb-card" data-slug={item.slug}>
            <div class="wb-card-top">
              <span class="wb-card-icon">{item.emoji}</span>
              <span class="wb-card-name">{item.name}</span>
              <span class={`wb-recency ${recencyClass(item.date)}`}>
                {relativeTime(item.date)}
              </span>
            </div>
            <h3 class="wb-card-title">{item.title}</h3>
            <p class="wb-card-summary">{item.summary}</p>
            {item.sectionsUpdated.length > 0 && (
              <div class="wb-card-badges">
                {item.sectionsUpdated.map((s) => (
                  <span class={`wb-badge ${badgeClass(s)}`}>{formatSectionLabel(s)}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .wb-section {
    width: 100%;
    background: var(--bg-primary);
    padding: 3rem 1.5rem 4rem;
  }

  .wb-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .wb-header {
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .wb-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--text-primary);
    text-transform: uppercase;
  }

  .wb-subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .wb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 1rem;
  }

  .wb-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.15rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .wb-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-light);
  }

  .wb-card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .wb-card-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .wb-card-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-primary);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .wb-recency {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15em 0.5em;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .wb-recency-green {
    color: var(--accent-green);
    background: var(--accent-green-dim);
  }

  .wb-recency-amber {
    color: var(--accent-amber);
    background: var(--accent-amber-dim);
  }

  .wb-recency-red {
    color: var(--accent-red);
    background: var(--accent-red-dim);
  }

  .wb-card-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.35rem;
    line-height: 1.35;
  }

  .wb-card-summary {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.65rem;
    flex: 1;
  }

  .wb-card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: auto;
  }

  .wb-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.5rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    padding: 0.15em 0.45em;
    border-radius: 3px;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .wb-badge-blue {
    color: var(--accent-blue);
    background: var(--accent-blue-dim);
  }

  .wb-badge-amber {
    color: var(--accent-amber);
    background: var(--accent-amber-dim);
  }

  .wb-badge-green {
    color: var(--accent-green);
    background: var(--accent-green-dim);
  }

  .wb-badge-red {
    color: var(--accent-red);
    background: var(--accent-red-dim);
  }

  .wb-badge-purple {
    color: var(--accent-purple);
    background: var(--accent-purple-dim);
  }

  .wb-badge-dim {
    color: var(--text-muted);
    background: rgba(148, 152, 168, 0.1);
  }

  @media (max-width: 480px) {
    .wb-section {
      padding: 2rem 1rem 3rem;
    }

    .wb-grid {
      grid-template-columns: 1fr;
    }

    .wb-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
