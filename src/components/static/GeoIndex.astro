---
interface TrackerEntry {
  slug: string;
  shortName: string;
  icon?: string;
  color?: string;
  description: string;
  lastUpdated: string;
  status: string;
}

interface ChildNode {
  id: string;
  label: string;
  trackerCount: number;
  href: string;
}

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  label: string;
  path: string[];
  trackers: TrackerEntry[];
  childNodes: ChildNode[];
  breadcrumb: BreadcrumbItem[];
}

const { label, path, trackers, childNodes, breadcrumb } = Astro.props;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const totalTrackers = trackers.length + childNodes.reduce((sum, c) => sum + c.trackerCount, 0);
---

<div class="geo-index">
  {/* Breadcrumb */}
  <nav class="geo-breadcrumb-nav" aria-label="Geographic breadcrumb">
    <a href={`${basePath}geo/`} class="geo-crumb-link">World</a>
    {breadcrumb.map((item) => (
      <>
        <span class="geo-crumb-sep">&rsaquo;</span>
        <a href={item.href} class="geo-crumb-link">{item.label}</a>
      </>
    ))}
  </nav>

  {/* Title */}
  <div class="geo-title-block">
    <h1 class="geo-title">{label}</h1>
    <span class="geo-count">{totalTrackers} tracker{totalTrackers !== 1 ? 's' : ''}</span>
  </div>

  {/* Sub-regions grid */}
  {childNodes.length > 0 && (
    <section class="geo-section">
      <h2 class="geo-section-heading">Sub-regions</h2>
      <div class="geo-children-grid">
        {childNodes.map((child) => (
          <a href={child.href} class="geo-child-card">
            <span class="geo-child-label">{child.label}</span>
            <span class="geo-child-count">{child.trackerCount} tracker{child.trackerCount !== 1 ? 's' : ''}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* Trackers grid */}
  {trackers.length > 0 && (
    <section class="geo-section">
      <h2 class="geo-section-heading">Trackers</h2>
      <div class="geo-trackers-grid">
        {trackers.map((t) => (
          <a href={`${basePath}${t.slug}/`} class="geo-tracker-card" style={`border-left-color: ${t.color || 'var(--accent-blue)'};`}>
            <div class="geo-tracker-header">
              {t.icon && <span class="geo-tracker-icon">{t.icon}</span>}
              <span class="geo-tracker-name">{t.shortName}</span>
              <span class={`geo-tracker-status geo-status-${t.status}`}>{t.status}</span>
            </div>
            <p class="geo-tracker-desc">{t.description}</p>
            <span class="geo-tracker-updated">Updated {t.lastUpdated}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* Empty state */}
  {childNodes.length === 0 && trackers.length === 0 && (
    <p class="geo-empty">No trackers found at this location.</p>
  )}
</div>

<style>
  .geo-index {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    font-family: 'DM Sans', sans-serif;
  }

  /* Breadcrumb */
  .geo-breadcrumb-nav {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    margin-bottom: 1rem;
  }
  .geo-crumb-link {
    color: var(--accent-blue, #3498db);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .geo-crumb-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
  .geo-crumb-sep {
    color: var(--text-muted, #8b8fa2);
  }

  /* Title */
  .geo-title-block {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 2rem;
  }
  .geo-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary, #e8e9ed);
    margin: 0;
  }
  .geo-count {
    font-size: 0.85rem;
    color: var(--text-muted, #8b8fa2);
  }

  /* Sections */
  .geo-section {
    margin-bottom: 2rem;
  }
  .geo-section-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted, #8b8fa2);
    margin: 0 0 0.75rem 0;
  }

  /* Sub-regions grid */
  .geo-children-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .geo-child-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 1rem;
    background: var(--bg-card, #181b23);
    border: 1px solid var(--border, #2a2d3a);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .geo-child-card:hover {
    border-color: var(--accent-blue, #3498db);
    background: var(--bg-card-hover, #1e2130);
  }
  .geo-child-label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary, #e8e9ed);
  }
  .geo-child-count {
    font-size: 0.8rem;
    color: var(--text-muted, #8b8fa2);
  }

  /* Trackers grid */
  .geo-trackers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }
  .geo-tracker-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 1rem;
    background: var(--bg-card, #181b23);
    border: 1px solid var(--border, #2a2d3a);
    border-left: 3px solid var(--accent-blue, #3498db);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .geo-tracker-card:hover {
    background: var(--bg-card-hover, #1e2130);
  }
  .geo-tracker-header {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .geo-tracker-icon {
    font-size: 1.1rem;
  }
  .geo-tracker-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary, #e8e9ed);
  }
  .geo-tracker-status {
    margin-left: auto;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 600;
  }
  .geo-status-active {
    color: var(--accent-green, #27ae60);
    background: rgba(39, 174, 96, 0.12);
  }
  .geo-status-archived {
    color: var(--text-muted, #8b8fa2);
    background: rgba(139, 143, 162, 0.12);
  }
  .geo-tracker-desc {
    font-size: 0.8rem;
    color: var(--text-muted, #8b8fa2);
    margin: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .geo-tracker-updated {
    font-size: 0.7rem;
    color: var(--text-muted, #8b8fa2);
    opacity: 0.7;
  }

  /* Empty state */
  .geo-empty {
    color: var(--text-muted, #8b8fa2);
    font-size: 0.9rem;
    text-align: center;
    padding: 3rem 1rem;
  }

  @media (max-width: 600px) {
    .geo-index {
      padding: 1.5rem 1rem;
    }
    .geo-title {
      font-size: 1.35rem;
    }
    .geo-children-grid {
      grid-template-columns: 1fr;
    }
    .geo-trackers-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
