---
/**
 * EmbedModal — surfaces the embed iframe snippet for a tracker.
 * Uses native <dialog> element. Zero-dependency, inline script. No React island needed.
 */
interface Props {
  trackerSlug: string;
  trackerName: string;
  siteUrl?: string;
}

const { trackerSlug, trackerName, siteUrl = 'https://watchboard.dev' } = Astro.props;

const embedUrl = `${siteUrl}/embed/${trackerSlug}/`;
const iframeSnippet = `<iframe src="${embedUrl}" width="360" height="220" style="border:none;border-radius:8px;" title="${trackerName} — Watchboard"></iframe>`;

const dialogId = `embed-dialog-${trackerSlug}`;
---

<button class="embed-trigger" data-dialog={dialogId} type="button" aria-haspopup="dialog">
  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="16 18 22 12 16 6"/>
    <polyline points="8 6 2 12 8 18"/>
  </svg>
  <span>Embed</span>
</button>

<dialog id={dialogId} class="embed-dialog" aria-labelledby={`${dialogId}-title`}>
  <div class="embed-dialog-inner">
    <!-- Header -->
    <div class="embed-dialog-header">
      <h2 id={`${dialogId}-title`} class="embed-dialog-heading">Embed {trackerName}</h2>
      <button class="embed-close-btn" data-close-dialog={dialogId} type="button" aria-label="Close embed dialog">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Description -->
    <p class="embed-dialog-desc">
      Copy this code to embed a live-updating widget on your site.
      ~4 KB, self-contained, auto-updates.
    </p>

    <!-- Code block + copy button -->
    <div class="embed-code-wrapper">
      <pre class="embed-code-block"><code>{iframeSnippet}</code></pre>
      <button
        class="embed-copy-btn"
        data-copy-text={iframeSnippet}
        type="button"
        aria-label="Copy embed code"
      >
        <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span class="copy-label">Copy</span>
      </button>
    </div>

    <!-- Preview -->
    <div class="embed-preview-section">
      <span class="embed-preview-label">Preview</span>
      <div class="embed-preview-frame">
        <iframe
          src={embedUrl}
          width="360"
          height="220"
          style="border:none;border-radius:8px;display:block;max-width:100%;"
          title={`${trackerName} — Watchboard`}
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </div>
</dialog>

<script>
  // Open dialog
  document.querySelectorAll<HTMLButtonElement>('.embed-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const dialogId = btn.dataset.dialog!;
      const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  // Close via close button
  document.querySelectorAll<HTMLButtonElement>('[data-close-dialog]').forEach(btn => {
    btn.addEventListener('click', () => {
      const dialogId = btn.dataset.closeDialog!;
      const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
      dialog?.close();
    });
  });

  // Close on backdrop click
  document.querySelectorAll<HTMLDialogElement>('.embed-dialog').forEach(dialog => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  });

  // Copy button
  document.querySelectorAll<HTMLButtonElement>('.embed-copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copyText!;
      const copyIcon = btn.querySelector<SVGElement>('.copy-icon')!;
      const checkIcon = btn.querySelector<SVGElement>('.check-icon')!;
      const label = btn.querySelector<HTMLSpanElement>('.copy-label')!;

      try {
        await navigator.clipboard.writeText(text);
        copyIcon.style.display = 'none';
        checkIcon.style.display = 'inline';
        label.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          copyIcon.style.display = 'inline';
          checkIcon.style.display = 'none';
          label.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      } catch {
        // Clipboard API not available — fallback
        prompt('Copy this embed code:', text);
      }
    });
  });
</script>

<style>
  /* ── Trigger button ── */
  .embed-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.35rem 0.7rem;
    color: var(--text-muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .embed-trigger:hover {
    border-color: var(--border-light);
    color: var(--text-secondary);
  }

  /* ── Dialog backdrop ── */
  .embed-dialog {
    position: fixed;
    inset: 0;
    margin: auto;
    max-width: min(520px, calc(100vw - 2rem));
    width: 100%;
    max-height: calc(100vh - 2rem);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0;
    color: var(--text-primary);
    font-family: 'DM Sans', sans-serif;
    overflow-y: auto;
    /* Resets for <dialog> */
    outline: none;
  }
  .embed-dialog::backdrop {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(2px);
  }

  /* ── Dialog inner ── */
  .embed-dialog-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Header ── */
  .embed-dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .embed-dialog-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }
  .embed-close-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3rem;
    color: var(--text-muted);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .embed-close-btn:hover {
    border-color: var(--border-light);
    color: var(--text-secondary);
  }

  /* ── Description ── */
  .embed-dialog-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Code block ── */
  .embed-code-wrapper {
    position: relative;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .embed-code-block {
    display: block;
    padding: 0.85rem 1rem;
    padding-right: 5.5rem;
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent-blue);
    white-space: pre-wrap;
    word-break: break-all;
    line-height: 1.6;
    overflow-x: auto;
  }
  .embed-code-block code {
    font-family: inherit;
  }
  .embed-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3rem 0.55rem;
    color: var(--text-muted);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .embed-copy-btn:hover {
    border-color: var(--border-light);
    color: var(--text-secondary);
  }
  .embed-copy-btn.copied {
    border-color: var(--accent-green);
    color: var(--accent-green);
  }

  /* ── Preview ── */
  .embed-preview-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .embed-preview-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .embed-preview-frame {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
</style>
