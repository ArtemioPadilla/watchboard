---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/static/Header.astro';
import HeroKpiCombo from '../../components/static/HeroKpiCombo.astro';
import CasualtyTable from '../../components/static/CasualtyTable.astro';
import EconGrid from '../../components/static/EconGrid.astro';
import ClaimsMatrix from '../../components/static/ClaimsMatrix.astro';
import PoliticalGrid from '../../components/static/PoliticalGrid.astro';
import SourceLegend from '../../components/static/SourceLegend.astro';
import EmbedModal from '../../components/static/EmbedModal.astro';
import Footer from '../../components/static/Footer.astro';
import GeoBreadcrumb from '../../components/static/GeoBreadcrumb.astro';

import TimelineSection from '../../components/islands/TimelineSection';
import IntelMapLoader from '../../components/islands/IntelMapLoader';
import MilitaryTabs from '../../components/islands/MilitaryTabs';
import LatestEvents from '../../components/islands/LatestEvents';
import MobileTabShellLoader from '../../components/islands/mobile/MobileTabShellLoader';

import { loadTrackerData } from '../../lib/data';
import { loadAllTrackers } from '../../lib/tracker-registry';
import type { TrackerConfig } from '../../lib/tracker-config';
import { flattenTimelineEvents } from '../../lib/timeline-utils';
import { eventPermalink } from '../../lib/event-slug';
import { countryName } from '../../lib/country-names';

export function getStaticPaths() {
  const trackers = loadAllTrackers();
  return trackers
    .filter(t => t.status !== 'draft')
    .map(t => ({
      params: { tracker: t.slug },
      props: { config: t },
    }));
}

interface Props {
  config: TrackerConfig;
}

const { config } = Astro.props;
const data = loadTrackerData(config.slug, config.eraLabel);
const flatEvents = flattenTimelineEvents(data.timeline);
const categories = config.map?.categories ?? [];

// Build dynamic status label from temporal + domain
const temporalLabel = config.temporal === 'historical' ? 'HISTORICAL' : 'ACTIVE';
const domainLabels: Record<string, string> = {
  conflict: 'CONFLICT', security: 'SECURITY', governance: 'GOVERNANCE',
  disaster: 'DISASTER', 'human-rights': 'HUMAN RIGHTS', science: 'SCIENCE',
  space: 'SPACE', economy: 'ECONOMY', culture: 'CULTURE', history: 'HISTORY',
};
const domainLabel = domainLabels[config.domain || ''] || 'TRACKER';
const statusLabel = `${temporalLabel} ${domainLabel}`;

const base = import.meta.env.BASE_URL || '/';
const basePath = base.endsWith('/') ? base : `${base}/`;
const siteUrl = import.meta.env.SITE || 'https://watchboard.dev';
const pageUrl = `${siteUrl}${basePath}${config.slug}/`;
const eventCount = flatEvents.length;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What is the ${config.name}?`,
      "acceptedAnswer": { "@type": "Answer", "text": config.description },
    },
    {
      "@type": "Question",
      "name": "How often is this tracker updated?",
      "acceptedAnswer": { "@type": "Answer", "text": `This tracker is updated every ${config.updateIntervalDays || 1} day(s) via automated AI research across Tier 1-4 sources.` },
    },
    {
      "@type": "Question",
      "name": "How many events are tracked?",
      "acceptedAnswer": { "@type": "Answer", "text": `${eventCount} events have been tracked since ${config.startDate}, with daily updates adding new developments.` },
    },
  ],
};
---
<BaseLayout
  title={`${config.shortName} — Intel Dashboard`}
  description={config.description}
  trackerSlug={config.slug}
  githubRepo={config.githubRepo}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Desktop layout -->
  <div class="desktop-layout">
    <Header meta={data.meta} navSections={config.navSections} trackerSlug={config.slug} globeEnabled={config.globe?.enabled} statusLabel={statusLabel} heroHeadline={data.meta.heroHeadline} dayCount={data.meta.dayCount} />
    <main id="main-content">
      <GeoBreadcrumb
        geoPath={config.geoPath}
        region={config.region}
        country={config.country ? countryName(config.country) : undefined}
        state={config.state}
        city={config.city}
        neighborhood={config.neighborhood}
      />

      <HeroKpiCombo meta={data.meta} kpis={data.kpis} />

      <!-- Server-rendered event previews for SEO crawlability -->
      <div class="seo-event-previews">
        <h2 class="seo-events-heading">Latest Events</h2>
        {flatEvents.slice(-5).reverse().map(ev => (
          <a href={eventPermalink(config.slug, ev.resolvedDate, ev.id, basePath)} class="seo-event-link">
            <time datetime={ev.resolvedDate}>
              {new Date(ev.resolvedDate + 'T00:00:00Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' })}
            </time>
            <span class="seo-event-title">{ev.title}</span>
            <span class="seo-event-tier">
              {ev.sources[0] && `Tier ${ev.sources[0].tier}`}
            </span>
          </a>
        ))}
      </div>

      <div class="theater-layout">
        {config.sections.includes('map') && (
          <div class="theater-map">
            <IntelMapLoader client:only="react" trackerSlug={config.slug} categories={categories} mapCenter={config.map?.center} mapBounds={config.map?.bounds} />
          </div>
        )}
        <div class={config.sections.includes('map') ? 'theater-scroll' : 'theater-scroll full-width'}>
          <LatestEvents client:visible events={flatEvents} />
          {config.sections.includes('military') && <MilitaryTabs client:visible strikeTargets={data.strikeTargets} retaliationData={data.retaliationData} assetsData={data.assetsData} tabs={config.militaryTabs} />}
          {config.sections.includes('casualties') && <CasualtyTable casualties={data.casualties} />}
          {config.sections.includes('economic') && <EconGrid econ={data.econ} />}
          {config.sections.includes('claims') && <ClaimsMatrix claims={data.claims} />}
          {config.sections.includes('political') && <PoliticalGrid political={data.political} avatarLabels={config.politicalAvatars} />}
          {config.sections.includes('timeline') && <TimelineSection client:visible timeline={data.timeline} />}
        </div>
      </div>

      <EmbedModal trackerSlug={config.slug} trackerName={config.shortName} />
      <SourceLegend />
    </main>
    <Footer meta={data.meta} trackerSlug={config.slug} githubRepo={config.githubRepo} />
  </div>

  <!-- Mobile layout -->
  <div class="mobile-layout">
    <MobileTabShellLoader
      client:only="react"
      operationName={data.meta.operationName}
      trackerSlug={config.slug}
      globeEnabled={config.globe?.enabled ?? false}
      isHistorical={config.temporal === 'historical'}
      categories={categories}
      mapCenter={config.map?.center}
      mapBounds={config.map?.bounds}
      cameraPresets={config.globe?.cameraPresets}
      endDate={config.endDate}
      clocks={config.globe?.clocks}
      militaryTabs={config.militaryTabs}
    />
  </div>

  <script define:vars={{ trackerSlug: config.slug }}>
    if (window.posthog) {
      window.posthog.register({ tracker_slug: trackerSlug });
      window.posthog.capture('tracker_viewed', { tracker_slug: trackerSlug });
    }
  </script>
</BaseLayout>

<style>
  .seo-event-previews {
    max-width: 900px;
    margin: 0 auto 1.5rem;
    padding: 0 1rem;
  }
  .seo-events-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .seo-event-link {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    transition: background 0.15s;
  }
  .seo-event-link:hover { background: var(--bg-card); }
  .seo-event-link time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-muted);
    flex-shrink: 0;
    min-width: 50px;
  }
  .seo-event-title {
    color: var(--text-secondary);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .seo-event-tier {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }
</style>
