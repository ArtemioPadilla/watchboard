---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CesiumGlobe from '../../components/islands/CesiumGlobe/CesiumGlobe';
import { loadTrackerData } from '../../lib/data';
import { loadAllTrackers } from '../../lib/tracker-registry';
import type { TrackerConfig } from '../../lib/tracker-config';
import { flattenTimelineEvents } from '../../lib/timeline-utils';
import '../../styles/globe.css';

export function getStaticPaths() {
  const trackers = loadAllTrackers();
  return trackers
    .filter(t => t.status !== 'draft' && t.globe?.enabled)
    .map(t => ({
      params: { tracker: t.slug },
      props: { config: t },
    }));
}

interface Props {
  config: TrackerConfig;
}

const { config } = Astro.props;
const data = loadTrackerData(config.slug, config.eraLabel);
const events = flattenTimelineEvents(data.timeline);

// Load mission trajectory if present — reuse data.ts loader
const missionTrajectory = data.missionTrajectory ?? null;

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
---
<BaseLayout title={`3D Intelligence Globe — ${config.shortName}`} trackerSlug={config.slug}>
  <main id="main-content">
  <div class="globe-layout">
    <div class="globe-slot globe-slot--top-left">
      <a href={`${basePath}${config.slug}/`} class="globe-back-link" data-i18n data-es="&larr; Panel" data-fr="&larr; Tableau de bord" data-pt="&larr; Painel">&larr; Dashboard</a>
      <a href={`${basePath}${config.slug}/about/`} class="globe-about-link" data-i18n data-es="Acerca de" data-fr="&Agrave; propos" data-pt="Sobre">About</a>
    </div>
    <CesiumGlobe
      client:only="react"
      points={data.mapPoints}
      lines={data.mapLines}
      kpis={data.kpis}
      meta={data.meta}
      events={events}
      cameraPresets={config.globe?.cameraPresets ?? {}}
      categories={config.map?.categories ?? []}
      mapCenter={config.map?.center ?? { lon: 0, lat: 0 }}
      isHistorical={config.temporal === 'historical'}
      endDate={config.endDate}
      clocks={config.globe?.clocks}
      missionTrajectory={missionTrajectory}
      globeLayout={config.globe?.layout ?? 'default'}
      layoutOverrides={config.globe?.layoutOverrides}
      />
  </div>

  <!-- Mobile mini-HUD -->
  <div class="globe-mobile-hud" aria-hidden="true">
    <span class="globe-mobile-hud-name">{config.shortName}</span>
    {config.startDate && (
      <span class="globe-mobile-hud-day" id="globe-day-count"></span>
    )}
  </div>

  <!-- Mobile gesture hint (first visit) -->
  <div class="globe-gesture-hint" id="globe-gesture-hint" style="display:none" role="status">
    <div class="globe-gesture-hint-inner">
      <span data-i18n data-es="Pellizca para zoom &middot; Arrastra para rotar" data-fr="Pincez pour zoomer &middot; Glissez pour pivoter" data-pt="Aperte para zoom &middot; Arraste para girar">Pinch to zoom &middot; Drag to rotate</span><br/><span data-i18n data-es="Desliza hacia arriba para eventos" data-fr="Tirez vers le haut pour les &eacute;v&eacute;nements" data-pt="Puxe para cima para eventos">Pull up for events</span>
    </div>
  </div>

  <script define:vars={{ trackerSlug: config.slug, startDate: config.startDate ?? null, serverDayCount: data.meta.dayCount ?? null }}>
    if (window.posthog) {
      window.posthog.register({ tracker_slug: trackerSlug });
      window.posthog.capture('globe_opened', { tracker_slug: trackerSlug });
    }

    // Day count for mini-HUD
    if (startDate) {
      const el = document.getElementById('globe-day-count');
      if (el) {
        const days = serverDayCount ?? Math.floor((Date.now() - new Date(startDate).getTime()) / 86400000);
        el.textContent = `DAY ${days.toLocaleString()}`;
      }
    }

    // Gesture hint — show once per tracker on mobile
    if (window.innerWidth <= 768) {
      const hintKey = `globe-hint-${trackerSlug}`;
      try { if (!localStorage.getItem(hintKey)) {
        const hint = document.getElementById('globe-gesture-hint');
        if (hint) {
          hint.style.display = '';
          const dismiss = () => { hint.style.display = 'none'; localStorage.setItem(hintKey, '1'); };
          hint.addEventListener('click', dismiss);
          hint.addEventListener('touchstart', dismiss, { passive: true });
          setTimeout(dismiss, 3000); } } catch(e) {}
        }
      }
    }
  </script>
  </main>
</BaseLayout>
