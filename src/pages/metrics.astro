---
import BaseLayout from '../layouts/BaseLayout.astro';
import MetricsDashboard from '../components/islands/MetricsDashboard';

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
---

<BaseLayout
  title="Ingestion Metrics — Watchboard"
  description="Nightly data update run history, validation status, and data inventory trends"
>
  <main id="main-content" class="metrics-page">
    <header class="metrics-header">
      <a class="metrics-home-link" href={basePath} title="Back to Watchboard">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Watchboard
      </a>
      <div class="metrics-title-row">
        <span class="section-num">M</span>
        <h1 class="metrics-title">Ingestion Metrics</h1>
      </div>
      <p class="metrics-subtitle">Nightly data update run history, validation status, and data inventory trends.</p>
    </header>
    <MetricsDashboard client:load />
  </main>
</BaseLayout>

<style>
  .metrics-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px 80px;
    min-height: 100vh;
  }

  .metrics-header {
    margin-bottom: 32px;
  }

  .metrics-home-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-family: 'DM Sans', sans-serif;
    margin-bottom: 16px;
    transition: color 0.2s;
  }

  .metrics-home-link:hover {
    color: var(--accent-blue);
  }

  .metrics-title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .section-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--accent-blue);
    color: #000;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .metrics-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .metrics-subtitle {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin: 0;
    font-family: 'DM Sans', sans-serif;
  }
</style>
