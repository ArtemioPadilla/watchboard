---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GeoIndex from '../../components/static/GeoIndex.astro';
import { loadAllTrackers } from '../../lib/tracker-registry';
import { loadTrackerData } from '../../lib/data';

const REGION_LABELS: Record<string, string> = {
  'north-america': 'North America',
  'central-america': 'Central America',
  'south-america': 'South America',
  'europe': 'Europe',
  'middle-east': 'Middle East',
  'africa': 'Africa',
  'central-asia': 'Central Asia',
  'south-asia': 'South Asia',
  'east-asia': 'East Asia',
  'southeast-asia': 'Southeast Asia',
  'oceania': 'Oceania',
  'global': 'Global',
};

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

const allTrackers = loadAllTrackers().filter(t => t.status !== 'draft');

// Group by region
const regionCounts = new Map<string, number>();
for (const t of allTrackers) {
  const region = t.region || 'global';
  regionCounts.set(region, (regionCounts.get(region) || 0) + 1);
}

// Build childNodes sorted by count descending
const childNodes = [...regionCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([region, count]) => ({
    id: region,
    label: REGION_LABELS[region] || region,
    trackerCount: count,
    href: `${basePath}geo/${region}/`,
  }));
---

<BaseLayout title="Geographic Index | Watchboard">
  <GeoIndex
    label="World"
    path={[]}
    trackers={[]}
    childNodes={childNodes}
    breadcrumb={[]}
  />
</BaseLayout>
