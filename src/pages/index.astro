---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadAllTrackers } from '../lib/tracker-registry';
import { loadTrackerData } from '../lib/data';
import CommandCenter from '../components/islands/CommandCenter/CommandCenter';
import WorldBriefing from '../components/static/WorldBriefing.astro';

interface BriefingItem {
  slug: string;
  name: string;
  emoji: string;
  date: string;
  title: string;
  summary: string;
  sectionsUpdated: string[];
  lastUpdated: string;
}

const trackers = loadAllTrackers();
const nonDraft = trackers.filter(t => t.status !== 'draft');
const active = trackers.filter(t => t.status === 'active');
const liveTrackers = active.filter(t => t.temporal !== 'historical');
const historicalTrackers = active.filter(t => t.temporal === 'historical');
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

// Serialize tracker data for the CommandCenter island
const serializedTrackers = nonDraft.map(t => {
  let topKpis: Array<{ value: string; label: string }> = [];
  let dayCount = 0;
  let lastUpdated = t.startDate;
  let headline: string | undefined;
  let headlineEs: string | undefined;
  let descriptionEs: string | undefined;
  let topKpisEs: Array<{ value: string; label: string }> = [];

  try {
    const data = loadTrackerData(t.slug, t.eraLabel);
    topKpis = data.kpis.slice(0, 3);
    dayCount = data.meta.dayCount;
    lastUpdated = data.meta.lastUpdated;
    headline = data.meta.heroHeadline?.replace(/<[^>]+>/g, ' ').replace(/\s{2,}/g, ' ').trim();
  } catch {
    // Tracker may not have data yet — use config defaults
  }

  // Load Spanish translations if available
  try {
    const esData = loadTrackerData(t.slug, t.eraLabel, 'es');
    headlineEs = esData.meta.heroHeadline?.replace(/<[^>]+>/g, ' ').replace(/\s{2,}/g, ' ').trim();
    topKpisEs = esData.kpis.slice(0, 3);
    descriptionEs = esData.meta.heroSubtitle || undefined;
  } catch {
    // No Spanish data available — will fall back to English
  }

  return {
    slug: t.slug,
    shortName: t.shortName,
    name: t.name,
    description: t.description,
    icon: t.icon,
    color: t.color,
    status: t.status,
    temporal: t.temporal,
    domain: t.domain,
    region: t.region,
    country: t.country,
    startDate: t.startDate,
    endDate: t.endDate,
    sections: t.sections,
    seriesId: t.series?.id,
    seriesName: t.series?.name,
    seriesOrder: t.series?.order,
    isHub: t.series?.isHub,
    mapEnabled: t.map?.enabled,
    globeEnabled: t.globe?.enabled,
    mapCenter: t.map?.center,
    dayCount,
    lastUpdated,
    headline,
    topKpis,
    headlineEs,
    descriptionEs,
    topKpisEs,
  };
});

// ── World Briefing: collect latest digest from each non-draft tracker ──
const SEVEN_DAYS_MS = 7 * 24 * 3600_000;
const now = Date.now();

const briefingItems: BriefingItem[] = nonDraft
  .map(t => {
    try {
      const data = loadTrackerData(t.slug, t.eraLabel);
      const latest = data.digests[0]; // digests are sorted newest-first
      if (!latest) return null;
      const age = now - new Date(latest.date).getTime();
      if (age > SEVEN_DAYS_MS) return null;
      return {
        slug: t.slug,
        name: t.shortName,
        emoji: t.icon ?? '📊',
        date: latest.date,
        title: latest.title,
        summary: latest.summary,
        sectionsUpdated: latest.sectionsUpdated ?? [],
        lastUpdated: data.meta.lastUpdated,
      } satisfies BriefingItem;
    } catch {
      return null;
    }
  })
  .filter((item): item is BriefingItem => item !== null)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---
<BaseLayout title="Watchboard — Intelligence Dashboard Platform">
  <main id="main-content">
  <CommandCenter
    trackers={serializedTrackers}
    basePath={basePath}
    liveCount={liveTrackers.length}
    historicalCount={historicalTrackers.length}
    client:load
  />
  <WorldBriefing items={briefingItems} basePath={basePath} />
  </main>
</BaseLayout>

<style is:global>
  /* Command center takes full viewport — allow scrolling to World Briefing below */
  body:has(.command-center-root) {
    overflow-x: hidden;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* Tablets/narrow desktops: stack globe + sidebar */
  @media (max-width: 767px) {
    .command-center-root {
      flex-direction: column !important;
      height: 100vh !important;
      height: 100dvh !important;
    }
    .cc-globe {
      flex: 0 0 35vh !important;
      height: 35vh !important;
      max-height: 35vh !important;
      overflow: hidden !important;
    }
    .cc-sidebar {
      flex: 1 1 0% !important;
      max-width: none !important;
      min-width: 0 !important;
      width: 100% !important;
      border-left: none !important;
      border-top: 1px solid var(--border) !important;
      overflow-y: auto !important;
      min-height: 0 !important;
    }
  }

  /* Phones: smaller globe */
  @media (max-width: 480px) {
    .cc-globe {
      flex: 0 0 25vh !important;
      height: 25vh !important;
      max-height: 25vh !important;
    }
    .cc-sidebar .cc-search-input {
      font-size: 0.7rem !important;
      padding: 5px 8px 5px 28px !important;
    }
  }

  /* Small phones */
  @media (max-width: 380px) {
    .command-center-root > div:first-child {
      height: 25vh !important;
      height: 25dvh !important;
      min-height: 150px !important;
    }
  }
</style>
